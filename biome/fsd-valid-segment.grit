language js

or {
  JsExportNamedFromClause() as $stmt,
  JsExportFromClause() as $stmt
} where {
  $filename <: r".*/src/(?:pages|widgets|features|entities)/[^/]+/index\.[^/]+$",
  $stmt <: contains `$src` where { $src <: r"\"\.\/([^/\"]+).*"($segment) },
  not {
    or {
      $segment <: "ui",
      $segment <: "model",
      $segment <: "api",
      $segment <: "lib",
      $segment <: "config"
    }
  },
  register_diagnostic(span=$src, message="FSD違反: セグメントディレクトリは ui, model, api, lib, config のみ許可されています。", severity="error")
}

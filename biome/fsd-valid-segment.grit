language js

or {
  JsImport() as $stmt,
  JsExportNamedFromClause() as $stmt,
  JsExportFromClause() as $stmt
} where {
  $stmt <: contains `$src` => . where { $src <: r"\".*" },
  or {
    $filename <: r".*/src/(?:pages|widgets|features|entities)/[^/]+/([^/]+)/.*"($segment),
    $filename <: r".*/src/(?:app|shared)/([^/]+)/.*"($segment)
  },
  not {
    or {
      $segment <: "ui",
      $segment <: "model",
      $segment <: "api",
      $segment <: "lib",
      $segment <: "config"
    }
  },
  register_diagnostic(span=$src, message="FSD違反: セグメントディレクトリは ui, model, api, lib, config のみ許可されています。", severity="error")
}

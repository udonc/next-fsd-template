language js

or {
  JsImport() as $stmt,
  JsExportNamedFromClause() as $stmt,
  JsExportFromClause() as $stmt
} where {
  $stmt <: contains `$src` => . where { $src <: r"\".*" },
  $filename <: r".*/src/([^/]+)/.*"($layer),
  not {
    or {
      $layer <: "app",
      $layer <: "pages",
      $layer <: "widgets",
      $layer <: "features",
      $layer <: "entities",
      $layer <: "shared"
    }
  },
  register_diagnostic(span=$src, message="FSD違反: src/ 直下には app, pages, widgets, features, entities, shared のみ配置できます。", severity="error")
}

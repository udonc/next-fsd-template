language js

or {
  `import $what from $src` where {
    $src <: r"\"\.\./\.\..*",
    register_diagnostic(
      span=$src,
      message="2階層以上の相対パスインポートは禁止です。パスエイリアスを使用してください。",
      severity="error"
    )
  },
  `export $what from $src` where {
    $src <: r"\"\.\./\.\..*",
    register_diagnostic(
      span=$src,
      message="2階層以上の相対パスインポートは禁止です。パスエイリアスを使用してください。",
      severity="error"
    )
  }
}

language js

or {
  // ============================================================
  // セグメント検証 (import)
  // スライスありレイヤー: src/<layer>/<slice>/<segment>/
  // スライスなしレイヤー: src/<layer>/<segment>/
  // 許可セグメント: ui, model, api, lib, config
  // ============================================================
  `import $what from $src` where {
    or {
      $filename <: r".*/src/(?:pages|widgets|features|entities)/[^/]+/([^/]+)/.*"($segment),
      $filename <: r".*/src/(?:app|shared)/([^/]+)/.*"($segment)
    },
    not {
      or {
        $segment <: "ui",
        $segment <: "model",
        $segment <: "api",
        $segment <: "lib",
        $segment <: "config"
      }
    },
    register_diagnostic(span=$src, message="FSD違反: セグメントディレクトリは ui, model, api, lib, config のみ許可されています。", severity="error")
  },
  // ============================================================
  // セグメント検証 (export ... from)
  // ============================================================
  `export $what from $src` where {
    or {
      $filename <: r".*/src/(?:pages|widgets|features|entities)/[^/]+/([^/]+)/.*"($segment),
      $filename <: r".*/src/(?:app|shared)/([^/]+)/.*"($segment)
    },
    not {
      or {
        $segment <: "ui",
        $segment <: "model",
        $segment <: "api",
        $segment <: "lib",
        $segment <: "config"
      }
    },
    register_diagnostic(span=$src, message="FSD違反: セグメントディレクトリは ui, model, api, lib, config のみ許可されています。", severity="error")
  }
}
